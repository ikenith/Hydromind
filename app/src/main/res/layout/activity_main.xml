<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f1a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💧 HydroMind"
            android:textSize="26sp"
            android:textColor="#4fc3f7"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"/>

        <!-- Streak -->
        <TextView
            android:id="@+id/tv_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 0 day streak"
            android:textSize="13sp"
            android:textColor="#a0b0c0"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"/>

        <!-- Progress Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1a2e"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tv_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="64sp"
                    android:textColor="#4fc3f7"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_goal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ 8 glasses"
                    android:textSize="18sp"
                    android:textColor="#a0b0c0"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:progress="0"
                android:max="100"
                android:progressTint="#4fc3f7"
                android:progressBackgroundTint="#2a2a4a"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tv_motivation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start your day right! 💧"
                android:textSize="14sp"
                android:textColor="#7ecff5"
                android:layout_gravity="center"/>

            <TextView
                android:id="@+id/tv_total_ml"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ml today"
                android:textSize="12sp"
                android:textColor="#607080"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Big Add Button -->
        <Button
            android:id="@+id/btn_add"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="+ Drink a glass"
            android:textSize="18sp"
            android:textColor="#0f0f1a"
            android:backgroundTint="#4fc3f7"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- Glass Size -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1a2e"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GLASS SIZE"
                android:textSize="11sp"
                android:textColor="#607080"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tv_ml"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="250 ml per glass"
                android:textSize="13sp"
                android:textColor="#a0b0c0"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <Button
                    android:id="@+id/btn_ml_250"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="250 ml"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_ml_350"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="350 ml"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_ml_500"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="500 ml"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Daily Goal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1a2e"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAILY GOAL"
                android:textSize="11sp"
                android:textColor="#607080"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <Button
                    android:id="@+id/btn_goal_6"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="6 glasses"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_goal_8"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="8 glasses"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_goal_10"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="10 glasses"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Reminders -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1a2e"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REMINDER INTERVAL"
                android:textSize="11sp"
                android:textColor="#607080"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <Button
                    android:id="@+id/btn_interval_1"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Every 1h"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_interval_2"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Every 2h"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_interval_3"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Every 3h"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Wake Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1a2e"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WAKE TIME"
                android:textSize="11sp"
                android:textColor="#607080"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <Button
                    android:id="@+id/btn_wake_early"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="6:00 AM"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_wake_normal"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="8:00 AM"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_wake_late"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="10:00 AM"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Sleep Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1a1a2e"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SLEEP TIME"
                android:textSize="11sp"
                android:textColor="#607080"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <Button
                    android:id="@+id/btn_sleep_early"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="8:00 PM"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_sleep_normal"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="10:00 PM"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_sleep_late"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="11:00 PM"
                    android:textSize="13sp"
                    android:textColor="#4fc3f7"
                    android:backgroundTint="#2a2a4a"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
